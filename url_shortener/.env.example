# Configuración del proyecto URL Shortener
# Copia este archivo como .env y ajusta los valores

# Base de datos — SQLite por defecto (no requiere instalación)
DATABASE_URL=sqlite:///./url_shortener.db

# Para PostgreSQL descomenta la línea siguiente:
# DATABASE_URL=postgresql://usuario:password@localhost:5432/urldb

# Puerto del servidor
PORT=8000
